# =============================================================================
# ngrok local development — copy to .env and fill in values
#   cp .env.example .env
# NEVER commit .env or ngrok.yml (both are gitignored)
# =============================================================================

# Required — get from https://dashboard.ngrok.com/get-started/your-authtoken
# Rotate immediately if this token was ever exposed in chat, logs, or git.
NGROK_AUTHTOKEN=

# Required — basic auth protects BOTH public tunnels (browser/API access)
NGROK_BASIC_AUTH_USER=dev
NGROK_BASIC_AUTH_PASS=change-me-to-a-long-random-password

# Optional — comma-separated CIDRs (requires ngrok paid plan for IP restrictions)
# Example: NGROK_IP_ALLOWLIST=203.0.113.10/32,198.51.100.0/24
NGROK_IP_ALLOWLIST=

# Optional — reserved domains (paid ngrok plan). Leave empty for random URLs.
# NGROK_FRONTEND_DOMAIN=
# NGROK_BACKEND_DOMAIN=

# Optional — restrict ngrok agent local API (tunnel list) to localhost
NGROK_WEB_ADDR=127.0.0.1:4040

# Spring Boot — set after tunnels start (scripts write .ngrok-urls.env automatically)
# SPRING_PROFILES_ACTIVE=ngrok
# APP_CORS_EXTRA_ORIGIN_PATTERNS=https://xxxx.ngrok-free.app

# Angular — backend public URL (without trailing slash)
# NGROK_BACKEND_URL=https://yyyy.ngrok-free.app
