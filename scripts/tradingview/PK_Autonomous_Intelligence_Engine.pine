// ALERTCONDITIONS (TradingView alert dialog — paste webhook URL + use alert() message)
// ═══════════════════════════════════════════════════════════════════════════════
alertcondition(bullishEdge, "BULLISH_CONTINUATION", "PK Intel BULLISH {{ticker}}")
alertcondition(putAplusEdge, "PUT_A_PLUS", "PK Intel PUT A+ {{ticker}}")
alertcondition(longBlockedEdge, "LONG_BLOCKED", "PK Intel LONG BLOCKED {{ticker}}")
alertcondition(conflictEdge and conflictLevel == "HIGH", "HIGH_CONFLICT", "PK Intel HIGH CONFLICT {{ticker}}")
alertcondition(collapseEdge, "COLLAPSING", "PK Intel COLLAPSING {{ticker}}")
alertcondition(failedReclaimEdge, "FAILED_RECLAIM", "PK Intel FAILED RECLAIM {{ticker}}")
alertcondition(pmStrongEdge, "PM_STRONG", "PK Intel PM STRONG {{ticker}}")
alertcondition(pmFailedGapEdge, "PM_FAILED_GAP", "PK Intel FAILED GAP {{ticker}}")
alertcondition(webhookFire, "WEBHOOK_PUSH", "PK Intel webhook edge {{ticker}}")
